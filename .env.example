# VulnX Application
VITE_API_URL=http://localhost:5000
SECRET_KEY=changeme-please
VULNX_DB_PATH=./vulnx.sqlite3

# Flask server
PORT=5000
FLASK_DEBUG=true

# SIEM Integration (Elasticsearch / Wazuh Indexer)
# Full REST URL including index path, e.g. Elasticsearch document endpoint:
SIEM_ENDPOINT=http://localhost:9200/vulnx-logs/_doc

# Optional authentication token (Bearer or ApiKey value)
# Accepted env vars: SIEM_TOKEN or API_TOKEN
SIEM_TOKEN=

# SIEM backend type: elasticsearch | wazuh | auto (default: auto-detect from URL)
SIEM_TYPE=auto

# Local fallback file when SIEM is unreachable after 3 retries
SIEM_FALLBACK_LOG=./siem_fallback.log
